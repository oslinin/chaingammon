{
  // VS Code Tasks for Chaingammon localhost dev (README "Mode B").
  //
  // Drop-in for .vscode/tasks.json. Each task pins a dedicated terminal
  // tab (`presentation.panel: "dedicated"`) and stays in the background
  // (`reveal: "never"`) so launching them does not surface any panels.
  //
  // Run via Cmd/Ctrl+Shift+P → "Tasks: Run Task" → pick one.
  // Use "Localhost: launch all" to start everything in the right order.
  //
  // Sequencing: the compound task runs children with
  // `dependsOrder: "sequence"`. The hardhat node task is a *background*
  // task whose problemMatcher.background.endsPattern matches Hardhat's
  // "Started HTTP and WebSocket JSON-RPC server" log line — VS Code
  // then considers the node ready and releases the deploy task. This
  // replaces the earlier `bash /dev/tcp` poll, which broke under VS
  // Code's nested-quote handling.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Localhost: hardhat node",
      "detail": "Terminal 1 — local EVM chain on http://127.0.0.1:8545 (chainId 31337). Long-running.",
      "type": "shell",
      // After the node exits (Ctrl+C, crash) drop into an interactive
      // shell in the same pane so you can re-run commands without
      // killing the terminal. Same trick on every task below.
      "command": "pnpm exec hardhat node; exec $SHELL",
      "options": { "cwd": "${workspaceFolder}/contracts" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "never",
        "focus": false,
        "clear": true
      },
      // The pattern entry is required by VS Code's task schema even
      // when we are not parsing problems. `regexp: "."` matches any
      // line; we only care about the background begin/end signals.
      "problemMatcher": {
        "owner": "hardhat-node",
        "pattern": [
          { "regexp": ".", "file": 1, "location": 2, "message": 0 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Hardhat Network",
          "endsPattern": "Started HTTP and WebSocket JSON-RPC server"
        }
      }
    },
    {
      "label": "Localhost: deploy contracts",
      "detail": "Terminal 2 — deploys MatchRegistry + AgentRegistry + PlayerSubnameRegistrar to localhost. Writes addresses to contracts/deployments/localhost.json. Runs once after the hardhat node is ready (one-shot).",
      "type": "shell",
      // Deliberately NOT chaining `; exec $SHELL` here. The deploy task is
      // one-shot and its exit is the signal that releases the next task in
      // the compound sequence (agent → frontend). If we dropped into a
      // shell the process would never exit and the sequence would stall.
      "command": "pnpm exec hardhat run script/deploy.js --network localhost",
      "options": { "cwd": "${workspaceFolder}/contracts" },
      "presentation": {
        "panel": "dedicated",
        "reveal": "never",
        "focus": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Localhost: agent node",
      "detail": "Terminal 3 — gnubg_service (port 8001) + coach_service (port 8002) + AXL relay if installed. Long-running.",
      "type": "shell",
      "command": "./start.sh; exec $SHELL",
      "options": { "cwd": "${workspaceFolder}/agent" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "never",
        "focus": false,
        "clear": true
      },
      // Background task — release the next sequential task as soon as
      // uvicorn signals at least one FastAPI service is up. Both
      // gnubg_service and coach_service emit "Application startup
      // complete." on success; matching once is enough to advance.
      "problemMatcher": {
        "owner": "agent-services",
        "pattern": [
          { "regexp": ".", "file": 1, "location": 2, "message": 0 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Started server process",
          "endsPattern": "Application startup complete"
        }
      }
    },
    {
      "label": "Localhost: frontend",
      "detail": "Terminal 4 — Next.js dev server on http://localhost:3000. Long-running.",
      "type": "shell",
      "command": "pnpm frontend:dev; exec $SHELL",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "reveal": "never",
        "focus": false,
        "clear": true
      },
      // Background task — Next.js prints "Ready in <ms>ms" once the dev
      // server is listening. Matching this releases the compound task
      // (currently the last child, but kept consistent for the future).
      "problemMatcher": {
        "owner": "next-dev",
        "pattern": [
          { "regexp": ".", "file": 1, "location": 2, "message": 0 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Next\\.js",
          "endsPattern": "Ready in"
        }
      }
    },
    {
      "label": "Localhost: launch all",
      "detail": "Compound task — runs children sequentially: hardhat node → (waits until ready) → deploy contracts → agent node → frontend. Each task lives in its own dedicated terminal tab.",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Localhost: hardhat node",
        "Localhost: deploy contracts",
        "Localhost: agent node",
        "Localhost: frontend"
      ],
      "problemMatcher": []
    }
  ]
}
