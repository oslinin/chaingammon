# ── 0G Chain ───────────────────────────────────────────────────────────────────
OG_RPC_URL=https://evmrpc-testnet.0g.ai
DEPLOYER_PRIVATE_KEY=0x<your-64-char-hex-private-key>

# ── 0G Storage ─────────────────────────────────────────────────────────────────
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-standard.0g.ai
OG_STORAGE_PRIVATE_KEY=0x<same-or-different-private-key>

# ── AXL (Gensyn Agent eXchange Layer) ─────────────────────────────────────────
# Set AXL_PORT if your AXL node listens on a non-default port.
AXL_PORT=7070
# AXL_CONFIG_PATH=agent/axl-config.json

# ── Optional ───────────────────────────────────────────────────────────────────
# CHAINSCAN_API_KEY=   # for contract verification (placeholder works on testnet)
