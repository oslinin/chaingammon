# Deployer wallet (never commit the real key)
DEPLOYER_PRIVATE_KEY=

# 0G testnet RPC
RPC_URL=https://evmrpc-testnet.0g.ai

# Sepolia RPC (only needed when deploying with --network sepolia).
# Defaults to publicnode if unset; override here for a private RPC.
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com

# ── Multichain testnet RPCs ──────────────────────────────────────────────────
# All default to their official public endpoints; override with private RPCs.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# ── Block explorer API keys (for contract verification) ──────────────────────
# ETHERSCAN_API_KEY covers Sepolia, Base Sepolia, Polygon Amoy, and Optimism Sepolia
# via the Etherscan V2 unified API. Get one at https://etherscan.io/myapikey.
ETHERSCAN_API_KEY=
# SnowTrace key for Avalanche Fuji verification. Get one at https://snowtrace.io.
SNOWTRACE_API_KEY=
# Optional per-chain overrides (falls back to ETHERSCAN_API_KEY if unset):
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=
