# 0G testnet
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# Deployed contract addresses (fill after Phase 2 deploy)
AGENT_REGISTRY_ADDRESS=
MATCH_REGISTRY_ADDRESS=

# 0G Storage (Phase 6) — used by og_storage_client via the og-bridge Node helper
# OG_STORAGE_PRIVATE_KEY can be the same wallet as DEPLOYER_PRIVATE_KEY for local dev.
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# On-chain MatchRegistry calls (Phase 7) — used by chain_client.py to call
# recordMatch as the contract owner. Mirror DEPLOYER_PRIVATE_KEY from
# contracts/.env locally; both .env files are gitignored.
DEPLOYER_PRIVATE_KEY=

# Encryption key for gnubg's base weights blob on 0G Storage (Phase 8).
# 32 bytes hex (64 chars). Generate once with:
#   uv run python scripts/upload_base_weights.py --print-fresh-key
# Anyone with this key can decrypt the weights blob from 0G Storage; treat
# it like the deployer key.
BASE_WEIGHTS_ENCRYPTION_KEY=

# Server
HOST=0.0.0.0
PORT=8000
