# Sepolia RPC — public node requires no API key; swap for Alchemy/Infura in production.
RPC_URL=https://ethereum-sepolia.publicnode.com
CHAIN_ID=11155111

# Deployed contract addresses on Sepolia. Copy from contracts/deployments/sepolia.json
# after running `pnpm contracts:deploy --network sepolia`.
AGENT_REGISTRY_ADDRESS=
MATCH_REGISTRY_ADDRESS=
MATCH_ESCROW_ADDRESS=
# PlayerSubnameRegistrar — server pushes ENS-shaped text records (`elo`, `last_match_id`)
# here from /finalize when a player has a registered ENS label.
PLAYER_SUBNAME_REGISTRAR_ADDRESS=

# On-chain calls — used by chain_client.py and agent_wallets.py to sign transactions
# as the contract owner. Mirror DEPLOYER_PRIVATE_KEY from contracts/.env; both files
# are gitignored.
DEPLOYER_PRIVATE_KEY=

# 0G Storage — used by og_storage_client.py via the og-bridge Node CLI.
# OG_STORAGE_PRIVATE_KEY can be the same wallet as DEPLOYER_PRIVATE_KEY for local dev.
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# Encryption key for the base weights blob stored on 0G Storage.
# 32 bytes hex (64 chars). Generate once with:
#   uv run python scripts/upload_base_weights.py --print-fresh-key
# Treat like the deployer key — anyone with this can decrypt the weights.
BASE_WEIGHTS_ENCRYPTION_KEY=

# Per-agent server-managed wallet keystores. Encrypts the v3 JSON keystores in
# server/data/agent_keys/. Losing this passphrase bricks every agent wallet whose
# owner hasn't withdrawn yet; rotate by re-keying every keystore file.
AGENT_KEYSTORE_PASSPHRASE=

# KeeperHub — workflow-driven match settlement.
# KH_API_KEY is your account-level API key from app.keeperhub.com (treat as a password).
# KEEPERHUB_WORKFLOW_ID is the workflow id the server triggers on match-end.
KH_API_KEY=
KEEPERHUB_WORKFLOW_ID=

# Keeper public key (Ethereum address) — the address for the KEEPER_PRIVKEY used in
# keeperhub/.env. The /settle endpoint verifies that keeperSig in each relayed payload
# was signed by this address. Omitting it disables signature verification.
#   cast wallet address --private-key <KEEPER_PRIVKEY>
KEEPER_PUBKEY=

# Server
HOST=0.0.0.0
PORT=8000
