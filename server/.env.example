# 0G testnet
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# Deployed contract addresses — usually leave blank.
# When unset, the server reads addresses from the matching network record
# in `contracts/deployments/<network>.json` keyed by CHAIN_ID, so a fresh
# `pnpm contracts:deploy` rolls through with no .env edit. Set explicitly
# only when you need to override a single address (e.g. point at a fork).
AGENT_REGISTRY_ADDRESS=
MATCH_REGISTRY_ADDRESS=
# PlayerSubnameRegistrar (Phase 11). Server pushes ENS-shaped text records
# (`elo`, `last_match_id`) here from /finalize when a side passes a label.
PLAYER_SUBNAME_REGISTRAR_ADDRESS=

# 0G Storage (Phase 6) — used by og_storage_client via the og-bridge Node helper
# OG_STORAGE_PRIVATE_KEY can be the same wallet as DEPLOYER_PRIVATE_KEY for local dev.
OG_STORAGE_RPC=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
OG_STORAGE_PRIVATE_KEY=

# On-chain MatchRegistry calls (Phase 7) — used by chain_client.py to call
# recordMatch as the contract owner. Mirror DEPLOYER_PRIVATE_KEY from
# contracts/.env locally; both .env files are gitignored.
DEPLOYER_PRIVATE_KEY=

# Encryption key for gnubg's base weights blob on 0G Storage (Phase 8).
# 32 bytes hex (64 chars). Generate once with:
#   uv run python scripts/upload_base_weights.py --print-fresh-key
# Anyone with this key can decrypt the weights blob from 0G Storage; treat
# it like the deployer key.
BASE_WEIGHTS_ENCRYPTION_KEY=

# KeeperHub (Phase 16+) — workflow-driven match settlement.
# KH_API_KEY is your account-level API key from app.keeperhub.com (treat as
# a password). KEEPERHUB_WORKFLOW_ID is the workflow id the server will
# trigger on match-end (set after building the workflow in Phase 17).
KH_API_KEY=
KEEPERHUB_WORKFLOW_ID=

# Server
HOST=0.0.0.0
PORT=8000
