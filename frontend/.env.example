# AXL gnubg agent node URL (the local gnubg_service from agent/).
# Used by the match flow page (frontend/app/match/page.tsx) for
# /new, /apply, /move, /resign. Defaults to localhost:8001 if unset.
NEXT_PUBLIC_GNUBG_URL=http://localhost:8001

# Legacy game-server URL — pre-pivot the match page hit this for /games
# endpoints. Retained here only for any pre-pivot tooling that still
# references it; the post-pivot match page does NOT use this.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional RPC override for 0G testnet (use a self-hosted RPC if you
# have one). Leave unset to fall back to https://evmrpc-testnet.0g.ai.
NEXT_PUBLIC_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Active chain selection now follows the wallet at runtime — switch
# networks in MetaMask and the UI re-targets that chain's contracts.
# Available chains and their addresses come from
# `contracts/deployments/<network>.json` via `frontend/app/chains.ts`.
# No NEXT_PUBLIC_CHAIN_ID or NEXT_PUBLIC_*_ADDRESS env vars needed.
