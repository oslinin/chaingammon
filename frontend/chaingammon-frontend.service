[Unit]
Description=ChainGammon Next.js frontend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/chaingammon/frontend
EnvironmentFile=/home/ubuntu/chaingammon/frontend/.env.local
ExecStart=/usr/bin/node node_modules/next/dist/bin/next dev --webpack
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
